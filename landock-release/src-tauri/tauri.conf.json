{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LanDock",
  "version": "0.1.0",
  "identifier": "com.landock.app",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3731",
    "beforeDevCommand": "node index.js",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "LanDock Hub",
        "width": 1150,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
